ANTHROPIC_API_KEY=your_anthropic_api_key_here
SESSION_SECRET=your_session_secret_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# 7-character PIN (format R######) that gates Rappel voice access
VOICE_PIN=R071201
PORT=4000

# Optional: absolute path to the SQLite file.
# Set this on Railway/Render to point at a persistent volume.
# Defaults to server/data/recall.db when not set.
# DATABASE_PATH=/mnt/data/recall.db
