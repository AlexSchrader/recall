ANTHROPIC_API_KEY=your_anthropic_api_key_here
SESSION_SECRET=a_long_random_string_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
RESEND_API_KEY=your_resend_api_key_here
VOICE_PIN=your_chosen_pin_here
PORT=4000

# SQLite path — set this on Railway to point at a persistent volume.
# Defaults to server/data/recall.db locally.
# DATABASE_PATH=/data/recall.db

# Comma-separated user IDs that can access /admin (usage & cost dashboard).
# To find your ID: log in, open browser console, run:
#   fetch('/api/me',{credentials:'include'}).then(r=>r.json()).then(d=>console.log(d.id))
# ADMIN_USER_IDS=your_user_id_here
